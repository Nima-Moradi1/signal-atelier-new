# Public production URL used by metadata, sitemap, and social cards.
NEXT_PUBLIC_SITE_URL=https://nimamoradirad.com

# Public contact address shown as the no-backend fallback.
NEXT_PUBLIC_CONTACT_EMAIL=nimamoradirad@gmail.com

# Optional Resend configuration. The site works without it and will offer a
# mailto fallback instead of pretending that a message was delivered.
RESEND_API_KEY=
CONTACT_DESTINATION_EMAIL=
CONTACT_FROM_EMAIL=Portfolio <portfolio@your-verified-domain.example>
